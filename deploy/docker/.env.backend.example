# 后端独立部署（Docker）示例（内网测试）
ENVIRONMENT=testing
DEBUG=False

DB_USER=kwok
DB_PASSWORD=change-me
DB_NAME=attendence

POSTGRES_BIND_IP=127.0.0.1
POSTGRES_PORT=5432
REDIS_BIND_IP=127.0.0.1
REDIS_PORT=6379
BACKEND_PORT=8000

# 逗号分隔，和后端配置兼容
CORS_ORIGINS=http://localhost,http://127.0.0.1,http://your-intranet-host
TRUSTED_HOSTS=localhost,127.0.0.1,your-intranet-host

SECRET_KEY=change-this-to-a-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
BACKEND_VERSION=local
BUILD_DATE=2026-02-25T00:00:00Z
