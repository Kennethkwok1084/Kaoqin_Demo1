{
  "name": "kaoqin-frontend-new",
  "version": "1.0.0",
  "description": "考勤管理系统前端 - 基于Vue 3 + TypeScript + Ant Design Vue",
  "private": true,
  "type": "module",
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" --",
    "preview": "vite preview",
    "test:unit": "vitest",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "generate-api-types": "openapi-typescript http://localhost:8000/openapi.json --output src/types/api.ts",
    "generate-api-client": "openapi-generator-cli generate -i http://localhost:8000/openapi.json -g typescript-axios -o src/api/generated",
    "generate-api": "npm run generate-api-types && npm run generate-api-client",
    "lint": "echo 'No linter configured yet'",
    "test": "vitest"
  },
  "dependencies": {
    "ant-design-vue": "^4.2.6",
    "axios": "^1.11.0",
    "echarts": "^6.0.0",
    "openapi-fetch": "^0.14.0",
    "pinia": "^3.0.3",
    "vue": "^3.5.18",
    "vue-router": "^4.5.1",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@openapitools/openapi-generator-cli": "^2.23.1",
    "@tsconfig/node22": "^22.0.2",
    "@types/jsdom": "^21.1.7",
    "@types/node": "^22.16.5",
    "@vitejs/plugin-vue": "^6.0.1",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.7.0",
    "jsdom": "^26.1.0",
    "npm-run-all2": "^8.0.4",
    "openapi-typescript": "^7.9.1",
    "typescript": "~5.8.0",
    "vite": "^7.0.6",
    "vite-plugin-vue-devtools": "^8.0.0",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.0.4"
  }
}
