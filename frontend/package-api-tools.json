{
  "name": "attendance-frontend",
  "version": "1.0.0",
  "description": "考勤管理系统前端 - 自动化API类型生成",
  "scripts": {
    "generate-api-types": "openapi-typescript http://localhost:8000/openapi.json --output src/types/api.ts",
    "generate-api-client": "@openapitools/openapi-generator-cli generate -i http://localhost:8000/openapi.json -g typescript-axios -o src/api/generated --additional-properties=supportsES6=true,npmName=attendance-api-client,npmVersion=1.0.0",
    "generate-api-fetch": "openapi-codegen -i http://localhost:8000/openapi.json -o src/api/generated-fetch",
    "start-backend": "cd ../backend && uvicorn app.main:app --host 0.0.0.0 --port 8000 --reload",
    "build-api-docs": "redoc-cli serve http://localhost:8000/openapi.json --title '考勤管理系统API文档' --output api-docs.html",
    "generate-all": "npm run generate-api-types && npm run generate-api-client",
    "dev-with-types": "npm run generate-api-types && npm run dev"
  },
  "devDependencies": {
    "openapi-typescript": "^6.7.4",
    "@openapitools/openapi-generator-cli": "^2.8.0", 
    "openapi-codegen": "^0.8.0",
    "redoc-cli": "^0.13.21",
    "openapi-fetch": "^0.8.2"
  },
  "dependencies": {
    "axios": "^1.6.2",
    "@types/node": "^20.10.4"
  }
}
