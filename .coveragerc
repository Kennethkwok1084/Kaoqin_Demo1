# Root coverage config for workspace-invoked pytest (aligns with backend/.coveragerc)

[run]
source = backend/app
branch = False
omit =
    */tests/*
    */test_*
    */migrations/*
    */alembic/*
    */scripts/*
    init_remote_db.py
    run_remote_migration.py
    seed_data.py
    */venv/*
    */.venv/*
    */env/*
    */__pycache__/*
    */site-packages/*
    # Release-scope exclusions (legacy/non-V2 surfaces)
    backend/app/api/v1/assistance.py
    backend/app/api/v1/attendance.py
    backend/app/api/v1/auth.py
    backend/app/api/v1/members_import_debug.py
    backend/app/api/v1/monitoring.py
    backend/app/api/v1/statistics.py
    backend/app/api/v1/system.py
    backend/app/api/v1/system_config.py
    backend/app/services/assistance_service.py
    backend/app/services/attendance_service.py
    backend/app/services/monitoring_service.py
    backend/app/services/repair_service.py
    backend/app/services/stats_service.py
    backend/app/services/work_hour_automation.py
    backend/app/services/work_hours_service.py

[report]
precision = 2
show_missing = True
skip_covered = False
sort = Cover
exclude_lines =
    pragma: no cover
    def __repr__
    if self\.debug
    raise AssertionError
    raise NotImplementedError
    if 0:
    if __name__ == .__main__.:
    @(abc\.)?abstractmethod
