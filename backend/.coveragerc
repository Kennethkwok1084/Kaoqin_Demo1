# Coverage.py configuration file
# https://coverage.readthedocs.io/en/latest/config.html

[run]
source = app
branch = False
omit = 
    */tests/*
    */test_*
    */migrations/*
    */alembic/*
    */scripts/*
    init_remote_db.py
    run_remote_migration.py
    seed_data.py
    */venv/*
    */.venv/*
    */env/*
    */__pycache__/*
    */site-packages/*
    # Release-scope exclusions (legacy/non-V2 surfaces)
    app/api/v1/assistance.py
    app/api/v1/attendance.py
    app/api/v1/auth.py
    app/api/v1/members_import_debug.py
    app/api/v1/monitoring.py
    app/api/v1/statistics.py
    app/api/v1/system.py
    app/api/v1/system_config.py
    app/services/assistance_service.py
    app/services/attendance_service.py
    app/services/monitoring_service.py
    app/services/repair_service.py
    app/services/stats_service.py
    app/services/work_hour_automation.py
    app/services/work_hours_service.py

[report]
precision = 2
show_missing = True
skip_covered = False
sort = Cover
exclude_lines =
    # Have to re-enable the standard pragma
    pragma: no cover
    
    # Don't complain about missing debug-only code:
    def __repr__
    if self\.debug
    
    # Don't complain if tests don't hit defensive assertion code:
    raise AssertionError
    raise NotImplementedError
    
    # Don't complain if non-runnable code isn't run:
    if 0:
    if __name__ == .__main__.:
    
    # Don't complain about abstract methods
    @(abc\.)?abstractmethod

[html]
directory = htmlcov
title = Kaoqin Demo Coverage Report

[xml]
output = coverage.xml

[json]
output = coverage.json
