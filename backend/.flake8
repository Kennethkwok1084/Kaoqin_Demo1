[flake8]
max-line-length = 88
extend-ignore = E203,W503,W504,C901
exclude = 
    .git,
    __pycache__,
    *.pyc,
    *.pyo,
    *.pyd,
    .pytest_cache,
    .mypy_cache,
    .venv,
    venv,
    .tox,
    build,
    dist,
    migrations,
    alembic/versions,
    node_modules
per-file-ignores =
    __init__.py:F401,F403
    tests/*:F401,F841
    scripts/*:E402
max-complexity = 10