# 测试环境配置 - 使用SQLite而不是PostgreSQL
APP_NAME=考勤管理系统_TEST
APP_VERSION=0.1.0
DEBUG=false
TESTING=true

# 服务器配置
HOST=0.0.0.0
PORT=8000
RELOAD=false

# 数据库配置 - 使用SQLite内存数据库进行测试
DATABASE_URL=sqlite+aiosqlite:///:memory:
DATABASE_URL_SYNC=sqlite:///:memory:

# 禁用PostgreSQL测试
POSTGRES_TEST=false

# 禁用Redis
REDIS_URL=

# 认证配置
SECRET_KEY=test-secret-key-for-testing-only
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=1

# 密码配置
PWD_CONTEXT_SCHEMES=["bcrypt"]
PWD_CONTEXT_DEPRECATED=["auto"]

# 加密配置
ENCRYPTION_KEY=test-encryption-key-32-bytes-long-key
SALT=test-salt-derivation

# CORS配置
CORS_ORIGINS=["http://localhost:3000"]
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=["*"]
CORS_ALLOW_HEADERS=["*"]

# 文件上传配置
MAX_FILE_SIZE=5242880
ALLOWED_FILE_TYPES=[".xlsx", ".xls", ".csv"]
UPLOAD_DIR=test_uploads

# 日志配置
LOG_LEVEL=WARNING
LOG_FORMAT=%(asctime)s - %(name)s - %(levelname)s - %(message)s
