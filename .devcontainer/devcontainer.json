{
  "name": "Kaoqin_demo",
  "dockerFile": "Dockerfile",
  "forwardPorts": [3000, 5173, 3001],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "esbenp.prettier-vscode",
        "dbaeumer.vscode-eslint",
        "Vue.volar",
        "Vue.vscode-typescript-vue-plugin"
      ]
    }
  },
  //"remoteUser": "root",

  // ---  在这里添加下面的内容 ---
  // 这个字段会为你容器里的所有进程设置好环境变量
  "containerEnv": {
    "http_proxy": "http://192.168.31.155:7890",  // 假设代理在服务器主机上，端口换成你自己的
    "https_proxy": "http://192.168.31.155:7890", // 端口换成你自己的
    "NO_PROXY": "localhost,127.0.0.1"       // 可选，让本地地址不走代理
  }
}