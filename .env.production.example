# 生产环境配置示例
# 复制此文件为 .env.production 并填入实际值

# 应用基本配置
ENVIRONMENT=production
APP_NAME=考勤管理系统
APP_VERSION=1.0.0

# 容器镜像配置
REGISTRY_URL=ghcr.io
IMAGE_PREFIX=your-org/attendance-system
VERSION=latest

# 数据库配置 - 生产环境
DB_USER=attendance_prod_user
DB_PASSWORD=super-strong-database-password
DB_NAME=attendence_prod
DB_HOST=postgres
DB_PORT=5432

# Redis配置 - 生产环境
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=strong-redis-password

# JWT配置 - 生产环境
SECRET_KEY=super-long-and-complex-secret-key-for-production-use
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# CORS配置 - 生产环境
CORS_ORIGINS=https://attendance.yourdomain.com,https://www.yourdomain.com

# SSL/TLS配置
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# 文件上传配置
UPLOAD_MAX_SIZE=52428800  # 50MB
UPLOAD_ALLOWED_EXTENSIONS=.xlsx,.xls,.csv

# 日志配置
LOG_LEVEL=INFO
LOG_FORMAT=json

# 邮件配置
SMTP_SERVER=smtp.yourdomain.com
SMTP_PORT=587
SMTP_USERNAME=noreply@yourdomain.com
SMTP_PASSWORD=your-smtp-password
SMTP_USE_TLS=true

# 监控配置
GRAFANA_PASSWORD=complex-grafana-admin-password
GRAFANA_SECRET_KEY=grafana-secret-key-for-sessions
GRAFANA_DB_NAME=grafana_prod
GRAFANA_DB_USER=grafana_user
GRAFANA_DB_PASSWORD=grafana-db-password

# 备份配置
BACKUP_RETENTION_DAYS=30
BACKUP_SCHEDULE="0 2 * * *"  # 每天凌晨2点

# 性能配置
WORKER_PROCESSES=4
WORKER_CONNECTIONS=1000
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=30